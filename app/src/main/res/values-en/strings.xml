    <string name="help_item_logo">Logo on the left in the header — your profile.</string>
    <string name="help_item_menu">Menu on the right (grid icon): settings, help, about, check for updates, report a bug, donate, and sign out.</string>
    <string name="help_item_tabs">Four tabs at the bottom: Friends, Messages, Security, and Easter eggs.</string>
    <string name="help_item_friends">Friends — your friends list. Tap a name to open a profile; the chat icon opens a conversation.</string>
    <string name="help_item_messages">Messages — conversations. Pick one to open the chat.</string>
