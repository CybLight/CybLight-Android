    <string name="help_item_background">Background — battery optimization and app permissions.</string>
    <string name="help_item_security">Security — manage active sign-in sessions.</string>
    <string name="help_item_easter">Easter eggs — secret achievements found on your account.</string>
    <string name="help_item_about">About — app description, website, and version number.</string>
