    <string name="help_title">Help</string>
    <string name="help_intro">A quick guide to the CybLight app.</string>
    <string name="help_section_main">Main screen</string>
    <string name="help_item_logo">Logo on the left in the header — your profile.</string>
    <string name="help_item_menu">Menu on the right (grid icon): settings, help, about, check for updates, report a bug, donate, and sign out.</string>
    <string name="help_item_tabs">Two tabs at the bottom: Friends and Messages.</string>
    <string name="help_item_friends">Friends — your friends list. Tap a name to open a profile; the chat icon opens a conversation.</string>
    <string name="help_item_messages">Messages — conversations. Pick one to open the chat.</string>
    <string name="help_section_settings">Settings</string>
    <string name="help_item_settings_open">Open settings from the header menu. Language and theme are also available there on the sign-in screen.</string>
    <string name="help_item_appearance">Appearance — theme (light, dark, system) and interface language.</string>
    <string name="help_item_notifications">Notifications — push permission and a shortcut to system notification settings.</string>
    <string name="help_item_background">Background — battery optimization and app permissions.</string>
    <string name="help_item_account">Account — security and active sessions, plus easter eggs you have found.</string>
    <string name="help_item_about">About — app description, website, and version number.</string>
    <string name="help_footer_hint">Tip: take a close look at the version line in About under settings — sometimes surprises hide there.</string>
